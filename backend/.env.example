PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/secure-file-manager
CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_with_a_second_long_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECURE=false
MASTER_ENCRYPTION_KEY_HEX=replace_with_64_hex_chars
FILE_STORAGE_PATH=./storage/files
MAX_FILE_SIZE_BYTES=5242880
SHARE_TOKEN_TTL_MINUTES=120
ENABLE_CLAMAV=false
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=super_secret
SMTP_FROM=Secure File Manager <no-reply@example.com>
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!
